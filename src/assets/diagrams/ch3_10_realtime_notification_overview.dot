digraph G {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.25",
    nodesep="0.45",
    ranksep="0.6",
    fontname="Arial"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Arial",
    fontsize=12,
    color="#64748b",
    penwidth=1.2,
    margin="0.12,0.08",
    fillcolor="#f8fafc",
    fontcolor="#0f172a"
  ];

  edge [
    color="#475569",
    arrowsize=0.7,
    penwidth=1.1,
    fontname="Arial",
    fontsize=10
  ];

  event [label="Business Event", fillcolor="#fff7ed", color="#f97316", fontcolor="#7c2d12"];
  save [label="notifications\nTable", shape=cylinder, fillcolor="#ecfdf5", color="#059669", fontcolor="#064e3b"];
  sse [label="SSE Emitter\nper User", fillcolor="#eef2ff", color="#4f46e5", fontcolor="#1e1b4b"];
  push [label="OneSignal\nif Configured", fillcolor="#fdf2f8", color="#db2777", fontcolor="#831843"];
  online [label="User Online\nin App", fillcolor="#eef6ff", color="#2563eb", fontcolor="#172554"];
  offline [label="Registered Browser\nor Device", fillcolor="#eef6ff", color="#2563eb", fontcolor="#172554"];
  ui [label="Update Badge /\nNotification Panel", fillcolor="#f0fdf4", color="#16a34a", fontcolor="#14532d"];
  browser [label="Push\nNotification", fillcolor="#f0fdf4", color="#16a34a", fontcolor="#14532d"];

  event -> save;
  save -> sse;
  save -> push;
  sse -> online -> ui;
  push -> offline -> browser;
}
