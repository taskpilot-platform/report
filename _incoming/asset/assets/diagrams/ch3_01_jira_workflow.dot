digraph JiraWorkflow {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.25",
    nodesep="0.45",
    ranksep="0.55",
    splines=polyline
  ];

  node [
    shape=box,
    style="rounded,filled",
    color="#65758b",
    fillcolor="#f8fafc",
    fontname="Arial",
    fontsize=12,
    margin="0.12,0.08"
  ];

  edge [
    color="#475569",
    fontname="Arial",
    fontsize=10,
    arrowsize=0.7
  ];

  Backlog [label="Jira backlog"];
  Sprint [label="Sprint"];
  Todo [label="To Do"];
  Progress [label="In Progress"];
  Review [label="Code Review / QA"];
  Done [label="Done", fillcolor="#f0fdf4", color="#16a34a"];
  Reports [label="Burndown / Reports"];
  Workflow [label="Custom workflow"];

  Backlog -> Sprint;
  Sprint -> Todo;
  Todo -> Progress;
  Progress -> Review;
  Review -> Done;
  Sprint -> Reports;
  Sprint -> Workflow;
}
