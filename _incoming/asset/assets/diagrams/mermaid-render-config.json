{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Inter, Arial, sans-serif",
    "primaryColor": "#f8fafc",
    "primaryTextColor": "#172033",
    "primaryBorderColor": "#65758b",
    "lineColor": "#475569",
    "secondaryColor": "#e8eef8",
    "tertiaryColor": "#ffffff"
  },
  "flowchart": {
    "htmlLabels": true,
    "curve": "stepAfter",
    "padding": 18,
    "defaultRenderer": "elk",
    "elk": {
      "mergeEdges": false,
      "nodePlacementStrategy": "NETWORK_SIMPLEX"
    }
  },
  "sequence": {
    "mirrorActors": false,
    "showSequenceNumbers": false
  }
}
